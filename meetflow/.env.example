# LiveKit Configuration
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_URL=ws://localhost:7880

# Database Configuration
DATABASE_URL=postgresql://meetflow:meetflow_password@localhost:5432/meetflow?schema=public

# NextAuth Configuration
NEXTAUTH_SECRET=your-secret-key-change-in-production-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# Google OAuth Configuration (get from console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# API Configuration
PORT=4000
NODE_ENV=development

# Public URL for frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
